<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="arm_base_length" value="0.1" />
    <xacro:property name="arm_base_width" value="0.1" />
    <xacro:property name="arm_base_height" value="0.02" />
    <xacro:property name="forearm_radius" value="0.02" />
    <xacro:property name="forearm_length" value="0.3" />
    <xacro:property name="hand_radius" value="0.02" />
    <xacro:property name="hand_length" value="0.3" />

<!-- Arm Links -->
    <link name="arm_base_link">
        <visual>
            <geometry>
                <box size="${arm_base_length}  ${arm_base_width}  ${arm_base_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_height/2.0}" rpy="0 0 0"/>
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <box size="${arm_base_length}  ${arm_base_width}  ${arm_base_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_height/2.0}" rpy="0 0 0"/>
        </collision>
        <xacro:box_inertia m="0.5" x="${arm_base_length}" y="${arm_base_width}" z="${arm_base_height}"
            o_xyz="0 0 ${arm_base_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="forearm_link">
        <visual>
            <geometry>
                <cylinder radius="${forearm_radius}" length="${forearm_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_length/2.0}" rpy="0 0 0"/>
            <material name="yellow" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${forearm_radius}" length="${forearm_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_length/2.0}" rpy="0 0 0"/>
        </collision>
        <xacro:cylinder_inertia m="0.3" radius="${forearm_radius}" length="${forearm_length}"
            o_xyz="0 0 ${forearm_length / 2.0}" o_rpy="0 0 0" />

    </link>

    <link name="hand_link">
        <visual>
            <geometry>
                <cylinder radius="${hand_radius}" length="${hand_length}" />
            </geometry>
            <origin xyz="0 0 ${hand_length/2.0}" rpy="0 0 0"/>
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${hand_radius}" length="${hand_length}" />
            </geometry>
            <origin xyz="0 0 ${hand_length/2.0}" rpy="0 0 0"/>
        </collision>
        <xacro:cylinder_inertia m="0.3" radius="${hand_radius}" length="${hand_length}"
            o_xyz="0 0 ${hand_length / 2.0}" o_rpy="0 0 0" />
    </link>


<!-- Joints -->
    <joint name="arm_base_forearm_joint" type="revolute">
        <parent link="arm_base_link" />
        <child link="forearm_link" />
        <limit lower="0" upper="${pi/2.0}" effort="100" velocity="100" />
        <dynamics friction="0.3" damping="0.3" />
        <origin xyz="0 0 ${arm_base_height}" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>
    
    <joint name="forearm_hand_joint" type="revolute">
        <parent link="forearm_link" />
        <child link="hand_link" />
        <limit lower="0" upper="${pi/2.0}" effort="100" velocity="100" />
        <dynamics friction="0.3" damping="0.3" />
        <origin xyz="0 0 ${forearm_length}" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_arm_base_joint" type="fixed">
        <parent link="base_link" />
        <child link="arm_base_link" />
        <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
    </joint>


<!-- Gazebo Plugins for controlling the arm joints and publishing their states -->
     <gazebo >
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>arm_base_forearm_joint</joint_name>
            <p_gain>5.0</p_gain>
            <topic>/arm_base_forearm_joint_position_cmd</topic>
        </plugin>   
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>forearm_hand_joint</joint_name>        
            <p_gain>3.0</p_gain>
            <topic>/forearm_hand_joint_position_cmd</topic>
        </plugin>   
    </gazebo>

      <!-- <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system"
                name="gz::sim::systems::JointStatePublisher"> -->
        <!-- <joint_name>base_left_wheel_joint</joint_name>
        <joint_name>base_right_wheel_joint</joint_name> -->
        <!-- <joint_name>arm_base_forearm_joint</joint_name>
        <joint_name>forearm_hand_joint</joint_name>
        </plugin>
    </gazebo> -->



</robot>